# MannMitra Environment Configuration
# Copy this file to .env and fill in your values

# Server
PORT=3000
NODE_ENV=development

# Database
DATABASE_PATH=./mannmitra.db

# Email (Gmail example — use an App Password if 2FA is enabled)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM="MannMitra <your-email@gmail.com>"
ADMIN_EMAIL=counsellor@example.com

# Admin Dashboard
ADMIN_PASSWORD=changeme123

# Session secret (use a long random string)
SESSION_SECRET=change-this-to-a-long-random-secret
