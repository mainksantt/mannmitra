<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MannMitra — New Features Preview</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=DM+Sans:wght@300;400;500;600&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
<style>
  :root {
    --indigo: #0F0F2E;
    --indigo-mid: #1A1A4E;
    --indigo-light: #252568;
    --gold: #F5A623;
    --gold-light: #FFD580;
    --gold-pale: #FFF4D6;
    --sage: #4CAF82;
    --sage-light: #A8D5B5;
    --sage-pale: #E8F5EE;
    --cream: #FBF8F3;
    --text-dark: #1C1C3E;
    --text-mid: #4A4A7A;
    --text-light: #8888AA;
    --red-alert: #E53E3E;
    --red-light: #FED7D7;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { font-family: 'DM Sans', sans-serif; background: var(--cream); color: var(--text-dark); }

  /* ─── SOS FLOATING WIDGET ─── */
  .sos-float {
    position: fixed; bottom: 28px; right: 28px; z-index: 9999;
    display: flex; flex-direction: column; align-items: flex-end; gap: 12px;
  }
  .sos-btn {
    width: 60px; height: 60px; border-radius: 50%;
    background: var(--red-alert); color: #fff;
    border: 3px solid #fff; cursor: pointer;
    font-family: 'Space Mono', monospace; font-size: 11px; font-weight: 700;
    letter-spacing: 0.5px; display: flex; flex-direction: column; align-items: center; justify-content: center;
    box-shadow: 0 4px 20px rgba(229, 62, 62, 0.5);
    transition: transform 0.2s, box-shadow 0.2s;
    animation: pulse-sos 2s infinite;
  }
  @keyframes pulse-sos {
    0%, 100% { box-shadow: 0 4px 20px rgba(229,62,62,0.5); }
    50% { box-shadow: 0 4px 32px rgba(229,62,62,0.9), 0 0 0 8px rgba(229,62,62,0.15); }
  }
  .sos-btn:hover { transform: scale(1.08); }
  .sos-btn svg { width: 20px; height: 20px; margin-bottom: 2px; }

  /* ─── SOS OVERLAY ─── */
  .sos-overlay {
    position: fixed; inset: 0; background: rgba(15,15,46,0.85);
    z-index: 9998; display: none; align-items: center; justify-content: center;
    padding: 20px;
  }
  .sos-overlay.active { display: flex; }
  .sos-panel {
    background: #fff; border-radius: 20px; max-width: 520px; width: 100%;
    max-height: 90vh; overflow-y: auto;
    box-shadow: 0 20px 60px rgba(0,0,0,0.3);
  }
  .sos-header {
    background: linear-gradient(135deg, var(--red-alert), #C53030);
    color: #fff; padding: 20px 24px 16px; border-radius: 20px 20px 0 0;
    display: flex; justify-content: space-between; align-items: flex-start;
  }
  .sos-header h2 { font-family: 'Playfair Display', serif; font-size: 1.4rem; margin-bottom: 4px; }
  .sos-header p { font-size: 13px; opacity: 0.85; }
  .sos-close {
    background: rgba(255,255,255,0.2); border: none; color: #fff;
    width: 32px; height: 32px; border-radius: 50%; cursor: pointer;
    font-size: 18px; display: flex; align-items: center; justify-content: center;
    flex-shrink: 0; transition: background 0.2s;
  }
  .sos-close:hover { background: rgba(255,255,255,0.35); }

  .sos-body { padding: 20px 24px; }

  .relief-tabs { display: flex; gap: 8px; margin-bottom: 20px; flex-wrap: wrap; }
  .relief-tab {
    padding: 7px 14px; border-radius: 20px; font-size: 13px; font-weight: 500;
    border: 1.5px solid var(--indigo-light); color: var(--indigo-light);
    cursor: pointer; transition: all 0.2s; background: transparent;
  }
  .relief-tab.active { background: var(--indigo); color: #fff; border-color: var(--indigo); }

  .relief-content { display: none; }
  .relief-content.active { display: block; }

  /* Breathing animation */
  .breath-circle {
    width: 120px; height: 120px; border-radius: 50%;
    background: radial-gradient(circle, rgba(76,175,130,0.3), rgba(76,175,130,0.1));
    border: 2px solid var(--sage); margin: 0 auto 16px;
    display: flex; align-items: center; justify-content: center;
    font-family: 'Space Mono', monospace; font-size: 28px; font-weight: 700;
    color: var(--sage); transition: transform 1s ease-in-out;
  }
  .breath-circle.inhale { transform: scale(1.35); background: radial-gradient(circle, rgba(76,175,130,0.5), rgba(76,175,130,0.2)); }
  .breath-circle.hold { transform: scale(1.35); }
  .breath-circle.exhale { transform: scale(0.9); }

  .breath-label { text-align: center; font-size: 15px; font-weight: 500; color: var(--text-mid); margin-bottom: 8px; }
  .breath-sub { text-align: center; font-size: 12px; color: var(--text-light); margin-bottom: 16px; }
  .breath-start {
    width: 100%; padding: 10px; border-radius: 10px;
    background: var(--sage); color: #fff; border: none; cursor: pointer;
    font-family: 'DM Sans', sans-serif; font-size: 14px; font-weight: 600;
    transition: background 0.2s;
  }
  .breath-start:hover { background: #3d9870; }

  /* Grounding */
  .ground-steps { counter-reset: step; }
  .ground-step {
    display: flex; gap: 12px; margin-bottom: 14px; align-items: flex-start;
  }
  .ground-num {
    width: 32px; height: 32px; border-radius: 50%; flex-shrink: 0;
    background: var(--gold-pale); color: var(--gold); 
    display: flex; align-items: center; justify-content: center;
    font-family: 'Space Mono', monospace; font-size: 13px; font-weight: 700;
    border: 1.5px solid var(--gold);
  }
  .ground-text strong { display: block; font-size: 14px; font-weight: 600; color: var(--text-dark); margin-bottom: 3px; }
  .ground-text span { font-size: 13px; color: var(--text-mid); }

  /* Helplines */
  .helpline-card {
    background: var(--sage-pale); border: 1.5px solid var(--sage-light);
    border-radius: 12px; padding: 12px 16px; margin-bottom: 10px;
    display: flex; align-items: center; gap: 12px;
  }
  .helpline-icon { font-size: 22px; }
  .helpline-name { font-size: 13px; font-weight: 600; color: var(--text-dark); }
  .helpline-num { font-family: 'Space Mono', monospace; font-size: 16px; font-weight: 700; color: var(--sage); }
  .helpline-time { font-size: 11px; color: var(--text-light); }

  /* WhatsApp */
  .wa-card {
    background: #f0fdf4; border: 1.5px solid #86efac;
    border-radius: 12px; padding: 14px 16px; margin-bottom: 10px;
    display: flex; justify-content: space-between; align-items: center;
  }
  .wa-info { }
  .wa-name { font-size: 14px; font-weight: 600; color: #166534; }
  .wa-desc { font-size: 12px; color: #4ade80; margin-top: 2px; }
  .wa-btn {
    background: #25D366; color: #fff; border: none; border-radius: 8px;
    padding: 7px 14px; font-size: 13px; font-weight: 600; cursor: pointer;
    display: flex; align-items: center; gap: 6px;
  }

  /* ─── VIGYAN / TRIBE V2 SECTION ─── */
  .vigyan-section {
    background: var(--indigo); color: #fff;
    padding: 80px 24px; position: relative; overflow: hidden;
  }
  .vigyan-section::before {
    content: 'विज्ञान'; position: absolute; top: -20px; right: -40px;
    font-family: 'Playfair Display', serif; font-size: 180px; opacity: 0.04;
    color: var(--gold); letter-spacing: -4px; line-height: 1; pointer-events: none;
  }
  .vigyan-container { max-width: 1100px; margin: 0 auto; }
  .vigyan-badge {
    display: inline-flex; align-items: center; gap: 8px;
    background: rgba(245,166,35,0.15); border: 1px solid rgba(245,166,35,0.4);
    color: var(--gold); padding: 6px 14px; border-radius: 20px;
    font-size: 12px; font-weight: 600; letter-spacing: 1px; text-transform: uppercase;
    margin-bottom: 24px;
  }
  .vigyan-title {
    font-family: 'Playfair Display', serif; font-size: clamp(2rem, 4vw, 3.2rem);
    font-weight: 700; line-height: 1.2; margin-bottom: 16px;
  }
  .vigyan-title .accent { color: var(--gold); }
  .vigyan-subtitle { font-size: 17px; opacity: 0.7; max-width: 580px; line-height: 1.7; margin-bottom: 48px; }

  .vigyan-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 32px; margin-bottom: 48px; }
  @media (max-width: 768px) { .vigyan-grid { grid-template-columns: 1fr; } }

  .vigyan-card {
    background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1);
    border-radius: 16px; padding: 24px; position: relative; overflow: hidden;
    transition: border-color 0.3s, background 0.3s;
  }
  .vigyan-card:hover { background: rgba(255,255,255,0.08); border-color: rgba(245,166,35,0.3); }
  .vigyan-card-icon {
    width: 44px; height: 44px; border-radius: 10px;
    background: rgba(245,166,35,0.15); display: flex; align-items: center; justify-content: center;
    margin-bottom: 14px;
  }
  .vigyan-card h3 { font-size: 1rem; font-weight: 600; margin-bottom: 8px; }
  .vigyan-card p { font-size: 14px; opacity: 0.65; line-height: 1.6; }
  .vigyan-stat {
    font-family: 'Space Mono', monospace; font-size: 2rem; font-weight: 700;
    color: var(--gold); display: block; margin-bottom: 4px;
  }

  .tribe-embed-box {
    background: rgba(255,255,255,0.04); border: 1.5px solid rgba(245,166,35,0.25);
    border-radius: 16px; padding: 24px; margin-top: 16px;
  }
  .tribe-embed-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px; flex-wrap: gap; }
  .tribe-label { font-size: 12px; letter-spacing: 1px; text-transform: uppercase; color: var(--gold); font-weight: 600; }
  .tribe-meta-badge {
    background: rgba(0,100,255,0.15); border: 1px solid rgba(0,100,255,0.3);
    color: #60a5fa; padding: 4px 10px; border-radius: 6px; font-size: 11px; font-weight: 600;
  }
  .tribe-iframe-wrapper {
    border-radius: 10px; overflow: hidden; border: 1px solid rgba(255,255,255,0.1);
    position: relative;
  }
  .tribe-iframe-wrapper iframe {
    width: 100%; height: 480px; border: none; display: block;
  }
  .tribe-disclaimer { font-size: 11px; opacity: 0.45; margin-top: 10px; line-height: 1.5; }

  /* ─── WISDOM SECTION ─── */
  .wisdom-section { padding: 80px 24px; background: var(--cream); }
  .wisdom-container { max-width: 1100px; margin: 0 auto; }
  .section-eyebrow {
    font-family: 'Space Mono', monospace; font-size: 11px; letter-spacing: 2px;
    text-transform: uppercase; color: var(--gold); font-weight: 700; margin-bottom: 12px;
  }
  .section-title {
    font-family: 'Playfair Display', serif; font-size: clamp(1.8rem, 3vw, 2.8rem);
    color: var(--text-dark); line-height: 1.25; margin-bottom: 12px;
  }
  .section-sub { font-size: 16px; color: var(--text-mid); max-width: 520px; line-height: 1.7; margin-bottom: 48px; }

  .wisdom-tabs { display: flex; gap: 0; margin-bottom: 36px; border-radius: 12px; overflow: hidden; border: 1.5px solid rgba(15,15,46,0.15); width: fit-content; }
  .wisdom-tab {
    padding: 10px 24px; font-size: 14px; font-weight: 600; border: none; cursor: pointer;
    background: #fff; color: var(--text-mid); transition: all 0.2s;
  }
  .wisdom-tab.active { background: var(--indigo); color: #fff; }

  .wisdom-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 20px; }
  .wisdom-card {
    background: #fff; border-radius: 16px; padding: 28px 24px;
    border: 1px solid rgba(15,15,46,0.07);
    transition: transform 0.25s, box-shadow 0.25s;
    position: relative; overflow: hidden;
  }
  .wisdom-card:hover { transform: translateY(-4px); box-shadow: 0 12px 40px rgba(0,0,0,0.08); }
  .wisdom-card::before {
    content: '"'; position: absolute; top: -12px; left: 16px;
    font-family: 'Playfair Display', serif; font-size: 100px; color: var(--gold-pale);
    line-height: 1; pointer-events: none;
  }
  .wisdom-source {
    font-family: 'Space Mono', monospace; font-size: 10px; letter-spacing: 1.5px;
    text-transform: uppercase; font-weight: 700; margin-bottom: 16px;
  }
  .wisdom-source.gita { color: var(--gold); }
  .wisdom-source.naval { color: var(--sage); }
  .wisdom-text {
    font-family: 'Playfair Display', serif; font-size: 1.05rem; line-height: 1.7;
    color: var(--text-dark); font-style: italic; margin-bottom: 14px;
  }
  .wisdom-context { font-size: 13px; color: var(--text-mid); line-height: 1.6; }
  .wisdom-ref { font-size: 11px; color: var(--text-light); margin-top: 10px; font-style: normal; }

  /* ─── COMMUNITY / WHATSAPP SECTION ─── */
  .community-section { background: var(--indigo-mid); padding: 72px 24px; }
  .community-container { max-width: 1000px; margin: 0 auto; }
  .community-header { text-align: center; margin-bottom: 48px; }
  .community-header .section-eyebrow { color: var(--sage-light); }
  .community-header .section-title { color: #fff; }
  .community-header .section-sub { color: rgba(255,255,255,0.6); margin: 0 auto 0; }

  .community-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 20px; }
  .community-card {
    background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1);
    border-radius: 16px; padding: 24px; transition: border-color 0.3s;
    display: flex; flex-direction: column; gap: 14px;
  }
  .community-card:hover { border-color: rgba(76,175,130,0.5); }
  .community-card-top { display: flex; align-items: center; gap: 12px; }
  .community-emoji { font-size: 28px; }
  .community-name { font-size: 15px; font-weight: 600; color: #fff; }
  .community-members { font-size: 12px; color: rgba(255,255,255,0.4); }
  .community-desc { font-size: 14px; color: rgba(255,255,255,0.6); line-height: 1.6; }
  .community-tags { display: flex; flex-wrap: wrap; gap: 6px; }
  .community-tag {
    background: rgba(76,175,130,0.15); color: var(--sage-light); border: 1px solid rgba(76,175,130,0.25);
    padding: 3px 10px; border-radius: 20px; font-size: 11px; font-weight: 500;
  }
  .community-join {
    background: #25D366; color: #fff; border: none; border-radius: 10px;
    padding: 10px 16px; font-family: 'DM Sans', sans-serif; font-size: 14px; font-weight: 600;
    cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 8px;
    transition: background 0.2s; width: 100%;
  }
  .community-join:hover { background: #1ebe5d; }

  /* ─── EMERGENCY RELIEF TECH SECTION ─── */
  .relief-section { background: var(--cream); padding: 72px 24px; }
  .relief-container { max-width: 1100px; margin: 0 auto; }
  .relief-feature-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 20px; margin-top: 40px; }
  .relief-feature-card {
    background: #fff; border-radius: 14px; padding: 24px;
    border-left: 4px solid var(--sage); border-top: 1px solid rgba(0,0,0,0.05);
    border-right: 1px solid rgba(0,0,0,0.05); border-bottom: 1px solid rgba(0,0,0,0.05);
    transition: transform 0.2s;
  }
  .relief-feature-card:hover { transform: translateY(-3px); }
  .relief-feature-card.urgent { border-left-color: var(--red-alert); }
  .relief-feature-card.calm { border-left-color: var(--gold); }
  .relief-num { font-family: 'Space Mono', monospace; font-size: 11px; color: var(--text-light); margin-bottom: 12px; }
  .relief-feature-name { font-weight: 600; font-size: 1rem; color: var(--text-dark); margin-bottom: 8px; }
  .relief-feature-desc { font-size: 13px; color: var(--text-mid); line-height: 1.6; }
  .relief-origin { font-size: 11px; color: var(--text-light); margin-top: 10px; font-style: italic; }

  /* ─── HERO PRODUCTS SECTION ─── */
  .hero-section {
    background: #fff; padding: 80px 24px;
    border-bottom: 1px solid rgba(0,0,0,0.06);
  }
  .hero-container { max-width: 1100px; margin: 0 auto; text-align: center; }
  .hero-products { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; margin-top: 48px; }
  @media (max-width: 768px) { .hero-products { grid-template-columns: 1fr; } }
  .hero-product {
    border-radius: 20px; padding: 36px 28px;
    position: relative; overflow: hidden; text-align: left;
    transition: transform 0.3s; cursor: pointer;
  }
  .hero-product:hover { transform: translateY(-6px); }
  .hp-mann { background: var(--indigo); color: #fff; }
  .hp-mitra { background: var(--gold-pale); color: var(--text-dark); }
  .hp-vigyan { background: var(--sage-pale); color: var(--text-dark); }
  .hp-label {
    font-family: 'Space Mono', monospace; font-size: 10px; letter-spacing: 2px;
    text-transform: uppercase; font-weight: 700; opacity: 0.6; margin-bottom: 12px; display: block;
  }
  .hp-name {
    font-family: 'Playfair Display', serif; font-size: 2rem; font-weight: 700;
    margin-bottom: 8px; display: block;
  }
  .hp-mann .hp-name { color: var(--gold); }
  .hp-mitra .hp-name { color: var(--indigo); }
  .hp-vigyan .hp-name { color: var(--sage); }
  .hp-meaning { font-size: 14px; margin-bottom: 16px; opacity: 0.7; font-style: italic; }
  .hp-desc { font-size: 14px; line-height: 1.7; opacity: 0.8; margin-bottom: 20px; }
  .hp-pill {
    display: inline-block; padding: 5px 14px; border-radius: 20px;
    font-size: 12px; font-weight: 600;
  }
  .hp-mann .hp-pill { background: rgba(245,166,35,0.2); color: var(--gold); }
  .hp-mitra .hp-pill { background: rgba(15,15,46,0.1); color: var(--indigo); }
  .hp-vigyan .hp-pill { background: rgba(76,175,130,0.2); color: #2d7a5b; }
  .hp-devanagari {
    position: absolute; bottom: -20px; right: -10px;
    font-family: 'Playfair Display', serif; font-size: 80px; opacity: 0.07; line-height: 1;
    pointer-events: none;
  }
  .hp-mann .hp-devanagari { color: #fff; opacity: 0.08; }

  /* ─── NAVBAR ─── */
  .navbar {
    position: sticky; top: 0; z-index: 100;
    background: rgba(15,15,46,0.92); backdrop-filter: blur(16px);
    padding: 0 32px; display: flex; align-items: center; justify-content: space-between;
    height: 64px; border-bottom: 1px solid rgba(255,255,255,0.07);
  }
  .nav-brand {
    font-family: 'Playfair Display', serif; font-size: 1.3rem; color: #fff;
    display: flex; align-items: center; gap: 8px;
  }
  .nav-brand span { color: var(--gold); }
  .nav-links { display: flex; gap: 28px; }
  .nav-links a { color: rgba(255,255,255,0.65); text-decoration: none; font-size: 14px; font-weight: 500; transition: color 0.2s; }
  .nav-links a:hover { color: #fff; }
  .nav-cta {
    background: var(--gold); color: var(--indigo); padding: 8px 20px;
    border-radius: 8px; font-size: 13px; font-weight: 700; border: none; cursor: pointer;
    transition: background 0.2s;
  }
  .nav-cta:hover { background: var(--gold-light); }

  /* ─── PAGE HEADER ─── */
  .page-note {
    background: linear-gradient(135deg, var(--indigo), var(--indigo-light));
    color: rgba(255,255,255,0.5); text-align: center; padding: 10px;
    font-size: 12px; font-family: 'Space Mono', monospace; letter-spacing: 1px;
  }
  .page-note span { color: var(--gold); }

  /* ─── MISC ─── */
  .text-center { text-align: center; }
  .mt-16 { margin-top: 16px; }
  .swot-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-top: 32px; }
  .swot-card { border-radius: 12px; padding: 20px; }
  .swot-s { background: #EAF5EE; border-left: 4px solid var(--sage); }
  .swot-w { background: #FFF4D6; border-left: 4px solid var(--gold); }
  .swot-o { background: #EEF0FF; border-left: 4px solid var(--indigo-light); }
  .swot-t { background: #FED7D7; border-left: 4px solid var(--red-alert); }
  .swot-label { font-family: 'Space Mono', monospace; font-size: 11px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; margin-bottom: 10px; }
  .swot-s .swot-label { color: var(--sage); }
  .swot-w .swot-label { color: #B7791F; }
  .swot-o .swot-label { color: var(--indigo-light); }
  .swot-t .swot-label { color: var(--red-alert); }
  .swot-card ul { padding-left: 16px; }
  .swot-card li { font-size: 13px; color: var(--text-mid); line-height: 1.7; }

  @media (max-width: 600px) {
    .nav-links { display: none; }
    .vigyan-grid { grid-template-columns: 1fr; }
    .hero-products { grid-template-columns: 1fr; }
    .swot-grid { grid-template-columns: 1fr; }
  }
</style>
</head>
<body>

<div class="page-note">MannMitra — New Features Preview · <span>Add these sections to your existing site</span></div>

<!-- ─── NAVBAR ─── -->
<nav class="navbar">
  <div class="nav-brand">मन<span>Mitra</span></div>
  <div class="nav-links">
    <a href="#mann">Mann</a>
    <a href="#mitra">Mitra</a>
    <a href="#vigyan">Vigyan</a>
    <a href="#wisdom">Wisdom</a>
    <a href="#community">Community</a>
  </div>
  <button class="nav-cta">Start Free</button>
</nav>

<!-- ─── HERO PRODUCTS ─── -->
