<script>
  function openSOS() { document.getElementById('sosOverlay').classList.add('active'); document.body.style.overflow = 'hidden'; }
  function closeSOS(e) { if (!e || e.target === document.getElementById('sosOverlay')) { document.getElementById('sosOverlay').classList.remove('active'); document.body.style.overflow = ''; stopBreathing(); } }

  function switchRelief(id, btn) {
    document.querySelectorAll('.relief-content').forEach(el => el.classList.remove('active'));
    document.querySelectorAll('.relief-tab').forEach(el => el.classList.remove('active'));
    document.getElementById('relief-' + id).classList.add('active');
    btn.classList.add('active');
    if (id !== 'breathe') stopBreathing();
  }

  let breathInterval = null, breathPhase = 0;
  const phases = [
    { label: 'Inhale...', sub: 'breathe in slowly through your nose', cls: 'inhale', counts: 4 },
    { label: 'Hold...', sub: 'hold your breath gently', cls: 'hold', counts: 7 },
    { label: 'Exhale...', sub: 'breathe out completely through your mouth', cls: 'exhale', counts: 8 }
  ];

  function startBreathing() {
    const btn = document.getElementById('breathBtn');
    btn.textContent = '⏹ Stop Exercise';
    btn.onclick = stopBreathing;
    runPhase(0, phases[0].counts);
  }

  function runPhase(phaseIdx, count) {
    const circle = document.getElementById('breathCircle');
    const label = document.getElementById('breathLabel');
    const sub = document.getElementById('breathSub');
    const p = phases[phaseIdx];
    circle.className = 'breath-circle ' + p.cls;
    circle.textContent = count;
    label.textContent = p.label;
    sub.textContent = p.sub;
    if (count > 1) {
      breathInterval = setTimeout(() => runPhase(phaseIdx, count - 1), 1000);
    } else {
      breathInterval = setTimeout(() => {
        const next = (phaseIdx + 1) % 3;
        runPhase(next, phases[next].counts);
      }, 1000);
    }
  }

  function stopBreathing() {
    clearTimeout(breathInterval);
    const circle = document.getElementById('breathCircle');
    const label = document.getElementById('breathLabel');
    const sub = document.getElementById('breathSub');
    const btn = document.getElementById('breathBtn');
    circle.className = 'breath-circle';
    circle.textContent = '4';
    label.textContent = 'Ready to breathe?';
    sub.textContent = '4-7-8 technique activates your parasympathetic system';
    if (btn) { btn.textContent = '▶ Start Breathing Exercise'; btn.onclick = startBreathing; }
  }

  function switchWisdom(type, btn) {
    document.getElementById('wisdom-gita').style.display = type === 'gita' ? 'grid' : 'none';
    document.getElementById('wisdom-naval').style.display = type === 'naval' ? 'grid' : 'none';
    document.querySelectorAll('.wisdom-tab').forEach(el => el.classList.remove('active'));
    btn.classList.add('active');
  }

  // Scroll animations
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting) { e.target.style.opacity = '1'; e.target.style.transform = 'translateY(0)'; } });
  }, { threshold: 0.1 });

  document.querySelectorAll('.vigyan-card, .wisdom-card, .community-card, .relief-feature-card, .hero-product').forEach(el => {
    el.style.opacity = '0'; el.style.transform = 'translateY(24px)';
    el.style.transition = 'opacity 0.6s ease, transform 0.6s ease';
    observer.observe(el);
  });
</script>
